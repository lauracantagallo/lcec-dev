---
layout: base.njk
---
<section class="hero">
  <div class="container hero__inner">
    <figure class="hero__logo">
      <img src="{{ '/img/lc-education-consulting_logo.jpg' | url }}" alt="LC Education Consulting Logo" width="548" height="548" />
    </figure>
    <div class="hero__content">
      <p class="hero__eyebrow">{{ hero.eyebrow }}</p>
      <h1 class="hero__heading">{{ hero.heading }}</h1>
      <p class="hero__subheading">{{ hero.subheading }}</p>
      <div class="hero__actions">
        <a href="{{ hero.cta_primary_url }}" class="btn btn--primary" target="_blank" rel="noopener">{{ hero.cta_primary_text }}</a>
        <a href="{{ hero.cta_secondary_url | url }}" class="btn btn--primary">{{ hero.cta_secondary_text }}</a>
      </div>
    </div>
  </div>
</section>

<section class="section section--blue">
  <div class="container">
    <h2 class="section-heading text-titlecase">{{ announcement.heading }}</h2>
    <p class="section-subheading">{{ announcement.subheading | safe }}</p>
    <p>{{ announcement.body }}</p>
    <a href="{{ announcement.link_url }}" class="btn btn--ghost mt-4" target="_blank" rel="noopener">{{ announcement.link_text }}</a>
  </div>
</section>

<section class="section section--white">
  <div class="container">
    <h2 class="section-lead text-center text-uppercase">{{ stats_heading }}</h2>
    <div class="stats-grid">
      {% for stat in stats %}
      <figure class="stat">
        <p class="stat__value">{{ stat.value }}</p>
        <figcaption class="stat__label">{{ stat.label }}</figcaption>
      </figure>
      {% endfor %}
    </div>
  </div>
</section>

<section class="section section--gray">
  <div class="container">
    <blockquote class="quote-block">
      <p class="quote-block__text">&ldquo;{{ quote.text }}&rdquo;</p>
      <footer class="quote-block__attribution">&mdash; {{ quote.attribution }}</footer>
    </blockquote>
  </div>
</section>

<section class="section section--white">
  <div class="container">
    <h2 class="social-section__heading">{{ social_heading }}</h2>
    <ul class="social-links">
      <li>
        <a href="{{ linkedin_url }}" class="social-link" target="_blank" rel="noopener" aria-label="LinkedIn">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="40" height="40" aria-hidden="true">
            <path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14m-.5 15.5v-5.3a3.26 3.26 0 0 0-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 0 1 1.4 1.4v4.93h2.79M6.88 8.56a1.68 1.68 0 0 0 1.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 0 0-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37h2.77z"/>
          </svg>
        </a>
      </li>
    </ul>
  </div>
</section>
